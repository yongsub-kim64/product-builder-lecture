---
import BaseLayout from '../layouts/BaseLayout.astro';
import LogCard from '../components/LogCard.astro';
import { getCollection } from 'astro:content';

const insightPosts = await getCollection('ko/insight', ({ data }) => data.published !== false);
const sortedPosts = insightPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="인사이트" description="AI Product Builder 전환 기록과 AX 실행 인사이트">
  <div class="insight-page">
    <header class="page-header">
      <h1>인사이트</h1>
      <p>AI Product Builder 전환 기록과 AX 실행 인사이트</p>
    </header>

    <div class="posts-grid">
      {/* TODO: guides 컬렉션이 3개 이상이면 동적 렌더링으로 전환 */}
      <LogCard
        title="바이브 코딩 입문서: 코딩을 몰라도 AI와 함께 앱 만드는 방법"
        excerpt="코딩을 깊게 알지 않아도 AI와 함께 MVP를 만들 수 있습니다. 기획 문서, 역할 분리, 검증 기준을 바탕으로 ChatGPT, Claude Code, Codex를 활용한 실전 바이브 코딩 흐름을 정리했습니다."
        date={new Date('2026-05-31')}
        slug="vibe-coding-guide"
        tags={["Guide", "바이브 코딩", "AI 코딩", "Claude Code"]}
        section="guides"
      />
      {sortedPosts.map((post) => (
        <LogCard
          title={post.data.title}
          excerpt={post.data.excerpt}
          date={post.data.date}
          slug={post.slug}
          tags={post.data.tags}
          section="insight"
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .insight-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(2rem, 1.5rem + 2.5vw, 4rem) clamp(1rem, 0.8rem + 1vw, 2rem);
  }

  .page-header {
    margin-bottom: clamp(2rem, 1.5rem + 2.5vw, 3rem);
  }

  .page-header h1 {
    font-size: clamp(1.75rem, 1.5rem + 1.25vw, 2.5rem);
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: #555;
    font-size: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
    gap: clamp(1.5rem, 1.2rem + 1.5vw, 2.5rem);
  }
</style>
