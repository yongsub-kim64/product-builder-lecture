---
import PageLayout from '../../layouts/PageLayout.astro';
---

<PageLayout
  title="Terms of Service"
  description="chulbuji.com Terms of Service — basic principles for using this public site"
>
  <div class="terms-page">
    <!-- Header -->
    <header class="terms-header">
      <p class="effective-date">Last Updated: April 23, 2026</p>
      <p class="intro-text">
        chulbuji.com is a public website for recording what I have built and learned while creating products with AI.<br>
        These Terms set out the basic principles for using this site.
      </p>
    </header>

    <!-- Quick Navigation -->
    <nav class="terms-nav">
      <p class="nav-title">Quick Navigation</p>
      <div class="nav-links">
        <a href="#section-1">About This Site</a>
        <a href="#section-2">User Conduct</a>
        <a href="#section-3">Limitation of Liability</a>
        <a href="#section-4">Intellectual Property</a>
        <a href="#section-5">Changes to Terms</a>
        <a href="#section-6">Contact</a>
      </div>
    </nav>

    <!-- Content Sections -->
    <div class="terms-content">
      <!-- Section 1 -->
      <section id="section-1" class="terms-section">
        <div class="section-number">01</div>
        <h2>About This Site</h2>
        <div class="section-content">
          <p>
            The site is organized around Log, Insight, and Project content — publicly accessible without registration.
          </p>
          <div class="highlight-box">
            <strong>Current Scope</strong>
            <p>This site does not currently offer membership registration or paid services. You can browse all public content without signing up. If new features are introduced, these Terms will be updated accordingly.</p>
          </div>
        </div>
      </section>

      <!-- Section 2 -->
      <section id="section-2" class="terms-section">
        <div class="section-number">02</div>
        <h2>User Conduct</h2>
        <div class="section-content">
          <p>When using this site, please follow these principles:</p>
          <ul class="obligation-list">
            <li>
              <span class="bullet">×</span>
              <span>Spread false information or infringe on others' rights</span>
            </li>
            <li>
              <span class="bullet">×</span>
              <span>Use automated tools (bots, crawlers, etc.) to access the site without authorization or generate excessive traffic</span>
            </li>
            <li>
              <span class="bullet">×</span>
              <span>Exploit vulnerabilities in the site or interfere with its operation</span>
            </li>
            <li>
              <span class="bullet">×</span>
              <span>Violate applicable laws or regulations</span>
            </li>
          </ul>
          <div class="warning-box">
            <strong>Tools Notice</strong>
            <p>
              Tools on this site (e.g., lottery number generator) are for <strong>educational and entertainment purposes only</strong>.
              They do not predict or guarantee results. You are solely responsible for decisions based on tool outputs.
            </p>
          </div>
        </div>
      </section>

      <!-- Section 3 -->
      <section id="section-3" class="terms-section">
        <div class="section-number">03</div>
        <h2>Limitation of Liability</h2>
        <div class="section-content">
          <p>
            Content on this site is provided for informational purposes. I do not guarantee its accuracy
            or completeness, and am not liable for:
          </p>
          <ul class="obligation-list">
            <li>
              <span class="bullet">—</span>
              <span>Decisions you make based on content from this site and their consequences</span>
            </li>
            <li>
              <span class="bullet">—</span>
              <span>The content or practices of third-party services linked from this site</span>
            </li>
            <li>
              <span class="bullet">—</span>
              <span>Site outages caused by force majeure (natural disasters, technical failures, etc.)</span>
            </li>
          </ul>
        </div>
      </section>

      <!-- Section 4 -->
      <section id="section-4" class="terms-section">
        <div class="section-number">04</div>
        <h2>Intellectual Property</h2>
        <div class="section-content">
          <p>
            All content on this site (text, images, code, design, etc.) is owned by the operator
            and protected by copyright.
          </p>
          <div class="info-box">
            <div class="info-row">
              <strong class="prohibited">🚫 Prohibited</strong>
              <span>Reproduction, redistribution, or commercial use without prior consent</span>
            </div>
            <div class="info-row">
              <strong class="allowed">✓ Allowed</strong>
              <span>Personal reference and non-commercial use, without removing attribution to the source</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Section 5 -->
      <section id="section-5" class="terms-section">
        <div class="section-number">05</div>
        <h2>Changes to Terms</h2>
        <div class="section-content">
          <div class="highlight-box">
            <strong>Updates</strong>
            <p>
              These Terms may be updated as the site evolves. Significant changes will be announced
              through a site notice. If new features are introduced, these Terms will be updated accordingly.
            </p>
          </div>
        </div>
      </section>

      <!-- Section 6 -->
      <section id="section-6" class="terms-section">
        <div class="section-number">06</div>
        <h2>Contact</h2>
        <div class="section-content">
          <p>For questions about these Terms or content copyright issues, please reach out:</p>
          <div class="contact-box">
            <strong>Email</strong>
            <a href="mailto:hello@chulbuji.com" class="contact-email">hello@chulbuji.com</a>
          </div>
        </div>
      </section>
    </div>
  </div>
</PageLayout>

<style>
  .terms-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  /* Header */
  .terms-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid #e0ddd8;
  }

  .terms-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 1rem;
  }

  .effective-date {
    font-size: 0.9rem;
    color: #888;
    margin-bottom: 1.5rem;
  }

  .intro-text {
    font-size: 1rem;
    line-height: 1.8;
    color: #555;
    max-width: 700px;
    margin: 0 auto;
  }

  /* Navigation */
  .terms-nav {
    background-color: #F7F3EE;
    border: 1px solid #ebe7e0;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 3rem;
  }

  .nav-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: #2C5F7C;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nav-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.75rem;
  }

  .nav-links a {
    padding: 0.5rem 1rem;
    background-color: white;
    border: 1px solid #e0ddd8;
    border-radius: 8px;
    text-decoration: none;
    color: #1a1a1a;
    font-size: 0.9rem;
    transition: all 0.2s;
    text-align: center;
  }

  .nav-links a:hover {
    border-color: #2C5F7C;
    color: #2C5F7C;
    transform: translateY(-1px);
  }

  /* Content Sections */
  .terms-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .terms-section {
    position: relative;
    scroll-margin-top: 2rem;
  }

  .section-number {
    position: absolute;
    left: -60px;
    top: 0;
    font-size: 3rem;
    font-weight: 700;
    color: #f0f0f0;
    line-height: 1;
  }

  .terms-section h2 {
    font-size: 1.8rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #2C5F7C;
  }

  .section-content {
    font-size: 1rem;
    line-height: 1.8;
    color: #333;
  }

  .section-content p {
    margin-bottom: 1rem;
  }

  /* Service Grid */
  .service-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .service-item {
    background-color: #FAFAF8;
    border: 1px solid #e0ddd8;
    border-radius: 8px;
    padding: 1.5rem;
  }

  .service-item strong {
    display: block;
    font-size: 1rem;
    color: #1a1a1a;
    margin-bottom: 0.5rem;
  }

  .service-item p {
    font-size: 0.9rem;
    color: #666;
    margin: 0;
  }

  /* Highlight Box */
  .highlight-box {
    background-color: #E8F0F5;
    border-left: 4px solid #2C5F7C;
    padding: 1.5rem;
    border-radius: 8px;
    margin-top: 1.5rem;
  }

  .highlight-box strong {
    display: block;
    color: #2C5F7C;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .highlight-box p {
    margin: 0;
    color: #555;
  }

  /* Warning Box */
  .warning-box {
    background-color: #FFF8E1;
    border-left: 4px solid #FFA726;
    padding: 1.5rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
  }

  .warning-box strong {
    display: block;
    color: #F57C00;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .warning-box p {
    margin: 0;
    color: #555;
  }

  /* Info Box */
  .info-box {
    background-color: #F7F3EE;
    border: 1px solid #ebe7e0;
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 1.5rem;
  }

  .info-row {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 0.75rem 0;
  }

  .info-row:not(:last-child) {
    border-bottom: 1px solid #e0ddd8;
  }

  .info-row strong {
    flex-shrink: 0;
    font-size: 0.9rem;
    padding: 0.25rem 0.75rem;
    border-radius: 6px;
    font-weight: 600;
  }

  .info-row strong.prohibited {
    background-color: #FFEBEE;
    color: #C62828;
  }

  .info-row strong.allowed {
    background-color: #E8F5E9;
    color: #2E7D32;
  }

  .info-row span {
    flex: 1;
    line-height: 1.6;
  }

  /* Info List */
  .info-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
  }

  .info-list li {
    padding: 0.75rem 0 0.75rem 2rem;
    position: relative;
  }

  .info-list li::before {
    content: '•';
    position: absolute;
    left: 0.5rem;
    color: #2C5F7C;
    font-weight: 700;
    font-size: 1.2rem;
  }

  /* Obligation List */
  .obligation-list {
    list-style: none;
    padding: 0;
    margin-top: 1.5rem;
  }

  .obligation-list li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem;
    background-color: #FAFAF8;
    border: 1px solid #e0ddd8;
    border-radius: 8px;
    margin-bottom: 0.75rem;
  }

  .obligation-list .bullet {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    background-color: #FFEBEE;
    color: #C62828;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.2rem;
  }

  .obligation-list span:last-child {
    flex: 1;
    line-height: 1.6;
  }

  /* Liability Grid */
  .liability-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .liability-item {
    background-color: #FAFAF8;
    border: 1px solid #e0ddd8;
    border-radius: 8px;
    padding: 1rem;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* Contact Box */
  .contact-box {
    background-color: white;
    border: 1px solid #e0ddd8;
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    margin-top: 1.5rem;
  }

  .contact-box strong {
    display: block;
    font-size: 0.85rem;
    color: #888;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-email {
    display: inline-block;
    font-size: 1.3rem;
    font-weight: 600;
    color: #2C5F7C;
    text-decoration: none;
    transition: color 0.2s;
  }

  .contact-email:hover {
    color: #1a3c50;
    text-decoration: underline;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .terms-page {
      padding: 1.5rem 1rem;
    }

    .terms-header h1 {
      font-size: 2rem;
    }

    .section-number {
      display: none;
    }

    .terms-section h2 {
      font-size: 1.5rem;
    }

    .nav-links {
      grid-template-columns: 1fr;
    }

    .info-row {
      flex-direction: column;
      gap: 0.5rem;
    }

    .service-grid,
    .liability-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
