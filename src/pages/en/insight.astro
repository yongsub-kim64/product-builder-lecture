---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LogCard from '../../components/LogCard.astro';
import { getCollection } from 'astro:content';

const insightPosts = await getCollection('en/insight', ({ data }) => data.published !== false);
const sortedPosts = insightPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Insight" description="AI Product Builder transformation records and AX execution insights">
  <div class="insight-page">
    <header class="page-header">
      <h1>Insight</h1>
      <p>AI Product Builder transformation records and AX execution insights</p>
    </header>

    <div class="posts-grid">
      {/* TODO: guides 컬렉션이 3개 이상이면 동적 렌더링으로 전환 */}
      <LogCard
        title="Vibe Coding Guide: How to Build Apps with AI Without Deep Coding Skills"
        excerpt="You don't need deep coding knowledge to build an MVP with AI. This guide covers planning documents, role separation, and validation criteria using ChatGPT, Claude Code, and Codex."
        date={new Date('2026-05-31')}
        slug="vibe-coding-guide"
        tags={["Guide", "vibe coding", "AI coding", "Claude Code"]}
        section="guides"
      />
      {sortedPosts.map((post) => (
        <LogCard
          title={post.data.title}
          excerpt={post.data.excerpt}
          date={post.data.date}
          slug={post.slug}
          tags={post.data.tags}
          section="insight"
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .insight-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(2rem, 1.5rem + 2.5vw, 4rem) clamp(1rem, 0.8rem + 1vw, 2rem);
  }

  .page-header {
    margin-bottom: clamp(2rem, 1.5rem + 2.5vw, 3rem);
  }

  .page-header h1 {
    font-size: clamp(1.75rem, 1.5rem + 1.25vw, 2.5rem);
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: #555;
    font-size: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
    gap: clamp(1.5rem, 1.2rem + 1.5vw, 2.5rem);
  }
</style>
