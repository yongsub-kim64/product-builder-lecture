---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy"
  description="chulbuji.com Privacy Policy — written to match the actual scope of this public content archive and project showcase site."
>
  <div class="privacy-container">

    <h1 class="privacy-title">Privacy Policy</h1>

    <div class="privacy-meta">
      <span>Effective: April 23, 2026</span>
      <span class="meta-sep">·</span>
      <span>Last updated: April 23, 2026</span>
    </div>

    <!-- Introduction -->
    <section class="privacy-intro">
      <p>chulbuji.com is a public website run by one person. It is a space for recording what I have built and learned while creating products with AI — organized primarily as a content archive, insight log, and project showcase.</p>

      <div class="info-box">
        This site does not currently operate membership registration or payment features. Information is handled only within the scope needed for site operation and responding to inquiries.
      </div>

      <p>If advertising, analytics tools, membership features, paid services, or other capabilities are introduced in the future, this policy will be updated to reflect those changes.</p>
    </section>

    <!-- Table of Contents -->
    <nav class="privacy-toc" aria-label="Table of contents">
      <p class="toc-label">Contents</p>
      <ol class="toc-list">
        <li><a href="#section-1">1. Information I Collect</a></li>
        <li><a href="#section-2">2. How I Use This Information</a></li>
        <li><a href="#section-3">3. Retention</a></li>
        <li><a href="#section-4">4. External Services and Links</a></li>
        <li><a href="#section-5">5. Your Requests</a></li>
        <li><a href="#section-6">6. Changes to This Policy</a></li>
        <li><a href="#section-7">7. Contact</a></li>
      </ol>
    </nav>

    <!-- 1. Information I Collect -->
    <section id="section-1" class="privacy-section">
      <h2>1. Information I Collect</h2>

      <div class="info-sub-box">
        <h3>Technical information collected automatically</h3>
        <p>When you access the site, the following information may be automatically recorded through standard web server operation:</p>
        <ul>
          <li>IP address</li>
          <li>Date and time of access</li>
          <li>Browser and device information</li>
          <li>Pages visited</li>
          <li>Error and security logs</li>
        </ul>
        <p class="sub-note">This information is used for site operation, error handling, and security management. It is not used to personally identify individual visitors.</p>
      </div>

      <div class="info-sub-box">
        <h3>Information you provide when contacting me</h3>
        <p>If you reach out via email or Google Form, I review the information necessary to respond to your inquiry:</p>
        <ul>
          <li>Email address</li>
          <li>Message content</li>
          <li>Any other information you voluntarily provide</li>
        </ul>
      </div>
    </section>

    <!-- 2. How I Use This Information -->
    <section id="section-2" class="privacy-section">
      <h2>2. How I Use This Information</h2>
      <p>I use the information collected solely for the following purposes:</p>
      <ul>
        <li>Site operation and error handling</li>
        <li>Security and basic operational management</li>
        <li>Reviewing and responding to inquiries</li>
      </ul>
      <p class="trust-note">I do not sell your information or use it for marketing or advertising purposes.</p>
    </section>

    <!-- 3. Retention -->
    <section id="section-3" class="privacy-section">
      <h2>3. Retention</h2>
      <p>Visit logs are retained for the period needed for operational and security purposes, then deleted.</p>
      <p>Email addresses and message content submitted through inquiries are deleted once the inquiry has been resolved and there is no further need to retain them. Deletion requests are processed without delay.</p>
    </section>

    <!-- 4. External Services and Links -->
    <section id="section-4" class="privacy-section">
      <h2>4. External Services and Links</h2>
      <p>This site contains links to external services, including:</p>
      <ul>
        <li>Email links (<a href="mailto:hello@chulbuji.com?subject=chulbuji.com%20Privacy%20Policy%20Inquiry">hello@chulbuji.com</a>)</li>
        <li>Google Form (inquiry form)</li>
        <li>GitHub and other external services</li>
      </ul>
      <div class="note-box">
        When you follow a link to an external service, that service's own privacy policy applies. Those interactions are outside the scope of this policy.
      </div>
    </section>

    <!-- 5. Your Requests -->
    <section id="section-5" class="privacy-section">
      <h2>5. Your Requests</h2>
      <p>You may request access to, correction of, or deletion of information you have submitted through an inquiry. Send your request to the email address below and I will review and process it.</p>
      <p><strong>Email:</strong> <a href="mailto:hello@chulbuji.com?subject=chulbuji.com%20Privacy%20Policy%20Inquiry">hello@chulbuji.com</a></p>
    </section>

    <!-- 6. Changes to This Policy -->
    <section id="section-6" class="privacy-section">
      <h2>6. Changes to This Policy</h2>
      <p>This policy may be updated as the site evolves. Changes will be announced through a site notice.</p>
    </section>

    <!-- 7. Contact -->
    <section id="section-7" class="privacy-section">
      <h2>7. Contact</h2>
      <div class="contact-box">
        <div class="contact-row">
          <span class="contact-label">Operator</span>
          <span>chulbuji</span>
        </div>
        <div class="contact-row">
          <span class="contact-label">Email</span>
          <a href="mailto:hello@chulbuji.com?subject=chulbuji.com%20Privacy%20Policy%20Inquiry">hello@chulbuji.com</a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .privacy-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 4rem;
  }

  /* Title */
  .privacy-title {
    font-size: clamp(1.5rem, 1.25rem + 1.25vw, 2rem);
    font-weight: 700;
    margin-bottom: 0.625rem;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  /* Meta dates */
  .privacy-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .meta-sep {
    color: var(--border-color);
  }

  /* Intro */
  .privacy-intro {
    margin-bottom: 2rem;
  }

  .privacy-intro > p {
    font-size: var(--font-size-base);
    line-height: 1.85;
    margin-bottom: 0.875rem;
    color: var(--text-color);
    max-width: 100%;
  }

  /* Info box */
  .info-box {
    background: #eef5fd;
    border: 1px solid #c5d9f0;
    border-radius: 6px;
    padding: 0.875rem 1.125rem;
    font-size: var(--font-size-base);
    line-height: 1.8;
    color: #2a4a6d;
    margin: 0.875rem 0;
  }

  /* TOC */
  .privacy-toc {
    background: var(--background-alt);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 1.125rem 1.375rem;
    margin-bottom: 0;
  }

  .toc-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.625rem !important;
    max-width: 100%;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .toc-list li {
    margin: 0;
    line-height: 1.5;
  }

  .toc-list a {
    font-size: var(--font-size-sm);
    color: var(--text-color);
    text-decoration: none;
    display: inline-block;
    padding: 0.1rem 0;
    transition: color 0.15s;
  }

  .toc-list a:hover {
    color: var(--primary-color);
  }

  /* Sections */
  .privacy-section {
    padding-top: 2.5rem;
    border-top: 1px solid var(--border-color);
    margin-top: 2.5rem;
  }

  .privacy-section h2 {
    font-size: clamp(1.0625rem, 1rem + 0.3125vw, 1.1875rem);
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--text-color);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .privacy-section > p {
    font-size: var(--font-size-base);
    line-height: 1.85;
    margin-bottom: 0.875rem;
    color: var(--text-color);
    max-width: 100%;
  }

  .privacy-section > p:last-child {
    margin-bottom: 0;
  }

  .privacy-section > ul {
    padding-left: 1.375rem;
    margin: 0.375rem 0 0.875rem;
  }

  .privacy-section > ul li {
    font-size: var(--font-size-base);
    line-height: 1.75;
    margin-bottom: 0.3125rem;
    color: var(--text-color);
  }

  .privacy-section > ul li:last-child {
    margin-bottom: 0;
  }

  /* Info sub-boxes */
  .info-sub-box {
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 1.125rem 1.25rem;
    margin-bottom: 0.875rem;
    background: white;
  }

  .info-sub-box:last-child {
    margin-bottom: 0;
  }

  .info-sub-box h3 {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: 0.625rem;
    line-height: 1.4;
  }

  .info-sub-box > p {
    font-size: var(--font-size-base);
    line-height: 1.8;
    margin-bottom: 0.625rem;
    color: var(--text-color);
    max-width: 100%;
  }

  .info-sub-box ul {
    padding-left: 1.25rem;
    margin: 0.375rem 0 0;
    list-style: disc;
  }

  .info-sub-box li {
    font-size: var(--font-size-base);
    line-height: 1.7;
    margin-bottom: 0.25rem;
    color: var(--text-color);
  }

  .info-sub-box li:last-child {
    margin-bottom: 0;
  }

  .sub-note {
    font-size: var(--font-size-sm);
    color: var(--text-muted);
    margin-top: 0.75rem;
    margin-bottom: 0 !important;
    line-height: 1.75;
  }

  /* Trust note */
  .trust-note {
    font-size: var(--font-size-sm);
    color: var(--text-muted);
    border-left: 3px solid var(--border-color);
    padding-left: 0.875rem;
    margin-top: 0.5rem;
    line-height: 1.75;
    max-width: 100%;
  }

  /* Note box */
  .note-box {
    background: #fafafa;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 0.875rem 1.125rem;
    font-size: var(--font-size-sm);
    color: var(--text-muted);
    line-height: 1.75;
    margin-top: 0.875rem;
  }

  /* Contact box */
  .contact-box {
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 1.125rem 1.375rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    font-size: var(--font-size-base);
    line-height: 1.6;
  }

  .contact-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-muted);
    min-width: 4rem;
    flex-shrink: 0;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .privacy-container {
      padding: 2rem 1rem 3rem;
    }

    .privacy-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2rem;
    }

    .meta-sep {
      display: none;
    }
  }
</style>
