---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const relatedLogs = (await getCollection('en/log', ({ data }) =>
  data.published !== false && data.project_tag === 'RunBuddy'
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const relatedInsights = (await getCollection('en/insight', ({ data }) =>
  data.published !== false && data.project_tag === 'RunBuddy'
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="Chulbuji RunBuddy"
  description="An early planning record for an AI running companion service — a shelved project preserving the initial problem framing and service direction."
>
  <div class="project-detail">

    <a href="/en/projects" class="back-link">← Projects</a>

    <div class="project-header">
      <span class="project-status status-on-hold">On Hold · Early Planning Record</span>
      <h1>Chulbuji RunBuddy</h1>
      <p class="project-lead">Chulbuji RunBuddy is not a project with active development in progress. It is a shelved project — preserving the initial planning and problem framing for an AI running companion service as a record.</p>
    </div>

    <section class="section">
      <h2>Current Status</h2>
      <p>No further development action is taking place. This project is maintained as an early planning record.</p>
      <p>The prototype concept for Android + Wear OS and the initial MVP structure have been documented, but no live service development or user testing is currently underway. The project remains in a state where it can be revisited when the conditions are right.</p>
    </section>

    <section class="section">
      <h2>Why It's On Hold</h2>
      <p>Current focus is on higher-priority projects: the AI auto-trading experiment, AI Content Assistant, and the AI blog/AdSense experiment.</p>
      <p>RunBuddy is a service idea tied to a personal running routine. Building a running service while that routine itself isn't active seemed like low-value work. Rather than building for the sake of building, the better choice is to revisit this when there's a genuine reason to use it.</p>
    </section>

    <section class="section">
      <h2>The Problem It Was Trying to Solve</h2>
      <p>The difficulty of running consistently on your own. More specifically:</p>
      <ul>
        <li>Vague goal-setting that leads to giving up mid-way or losing direction</li>
        <li>Difficulty managing execution flow — pace, distance, timing — without help</li>
        <li>Inconsistent logging that leads to a recurring drop in motivation</li>
        <li>Lower training quality from running without real-time feedback</li>
      </ul>
      <p>The hypothesis was that if AI could act as a running companion for solo runners, it could meaningfully improve goal completion rates and consistency over time.</p>
    </section>

    <section class="section">
      <h2>Initial Service Direction</h2>
      <p>The concept: input your fitness level and goals, and AI proposes a weekly running plan and execution structure — then provides real-time coaching while you run.</p>
      <ul>
        <li><strong>Android app + Wear OS watch integration</strong> — a dual-device structure using both phone and smartwatch</li>
        <li><strong>Real-time pace and heart rate monitoring</strong> — state detection based on watch sensor data</li>
        <li><strong>500m interval coaching</strong> — immediate voice coaching when targets are missed</li>
        <li><strong>Log accumulation and feedback</strong> — preserving each run as a record to support consistency</li>
      </ul>
    </section>

    <section class="section">
      <h2>Conditions for Resuming</h2>
      <p>This project may be revisited if the following conditions are met:</p>
      <ul>
        <li>A personal running routine resumes and creates a genuine reason to use the service</li>
        <li>A simple logging template allows the usage flow to be validated first</li>
        <li>A small, well-defined MVP scope becomes clear — starting with one core feature, not a full app</li>
        <li>Shifts in priority across current active projects</li>
      </ul>
    </section>

    <section class="section">
      <h2>Related Records</h2>
      {relatedLogs.length > 0 ? (
        <div class="related-group">
          <h3 class="related-label">Log</h3>
          <ul class="related-list">
            {relatedLogs.map(post => (
              <li>
                <a href={`/en/log/${post.slug}`}>{post.data.title}</a>
                <span class="post-date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
              </li>
            ))}
          </ul>
        </div>
      ) : null}
      {relatedInsights.length > 0 ? (
        <div class="related-group">
          <h3 class="related-label">Insight</h3>
          <ul class="related-list">
            {relatedInsights.map(post => (
              <li>
                <a href={`/en/insight/${post.slug}`}>{post.data.title}</a>
                <span class="post-date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
              </li>
            ))}
          </ul>
        </div>
      ) : null}
      {relatedLogs.length === 0 && relatedInsights.length === 0 && (
        <p class="no-records">No records are currently linked to this project.</p>
      )}
    </section>

  </div>
</BaseLayout>

<style>
  .project-detail {
    max-width: 720px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 4rem;
  }

  .back-link {
    display: inline-block;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--primary-color);
  }

  .project-header {
    margin-bottom: 2.5rem;
  }

  .project-status {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.8125rem;
    font-weight: 600;
    margin-bottom: 0.875rem;
  }

  .status-on-hold {
    background: #f5f5f5;
    color: #757575;
  }

  .project-header h1 {
    font-size: clamp(1.625rem, 1.25rem + 1.875vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .project-lead {
    font-size: var(--font-size-base);
    line-height: 1.85;
    color: var(--text-muted);
    border-left: 3px solid var(--border-color);
    padding-left: 1rem;
    margin: 0;
    max-width: 100%;
  }

  .section {
    padding-top: 2.25rem;
    border-top: 1px solid var(--border-color);
    margin-bottom: 0;
  }

  .section h2 {
    font-size: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
    font-weight: 700;
    margin-bottom: 0.875rem;
    color: var(--text-color);
    letter-spacing: -0.01em;
  }

  .section p {
    font-size: var(--font-size-base);
    color: var(--text-color);
    line-height: 1.85;
    margin-bottom: 0.875rem;
    max-width: 100%;
  }

  .section p:last-child {
    margin-bottom: 0;
  }

  .section ul {
    padding-left: 1.375rem;
    margin: 0.5rem 0 0.875rem;
    list-style: disc;
  }

  .section ul li {
    font-size: var(--font-size-base);
    line-height: 1.75;
    margin-bottom: 0.375rem;
    color: var(--text-color);
  }

  .section ul li:last-child {
    margin-bottom: 0;
  }

  /* Related records */
  .related-group {
    margin-bottom: 1.25rem;
  }

  .related-group:last-child {
    margin-bottom: 0;
  }

  .related-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
    letter-spacing: 0.04em;
  }

  .related-list {
    padding-left: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin: 0;
  }

  .related-list li {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin: 0;
  }

  .related-list a {
    color: var(--primary-color);
    text-decoration: none;
    font-size: var(--font-size-base);
    font-weight: 500;
    line-height: 1.4;
  }

  .related-list a:hover {
    text-decoration: underline;
  }

  .post-date {
    font-size: 0.8125rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .no-records {
    font-size: var(--font-size-sm);
    color: var(--text-muted);
  }

  @media (max-width: 480px) {
    .project-detail {
      padding: 2rem 1rem 3rem;
    }
  }
</style>
