---
import PageLayout from '../../../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const relatedLogs = (await getCollection('en/log', ({ data }) =>
  data.published !== false && data.project_tag === 'RunBuddy'
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const relatedInsights = (await getCollection('en/insight', ({ data }) =>
  data.published !== false && data.project_tag === 'RunBuddy'
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<PageLayout title="Chulbuji RunBuddy" description="AI voice coaching running app for Android + Wear OS dual devices. Monitors real-time pace and heart rate, delivering instant voice coaching when targets are missed.">
  <div class="project-detail">
    <a href="/en/projects" class="back-link">← Projects</a>

    <div class="project-header">
      <span class="project-status status-active">In Progress</span>
      <h1>Chulbuji RunBuddy</h1>
    </div>

    <section class="section">
      <h2>Overview</h2>
      <p>AI voice coaching running app for Android + Wear OS dual devices. Monitors real-time pace and heart rate, delivering instant voice coaching when targets are missed.</p>
    </section>

    <section class="section">
      <h2>Current Status</h2>
      <p>Outdoor real-world testing in progress.</p>
    </section>

    <section class="section">
      <h2>Related Logs</h2>
      {relatedLogs.length > 0 ? (
        <ul class="related-list">
          {relatedLogs.map(post => (
            <li>
              <a href={`/en/log/${post.slug}`}>{post.data.title}</a>
              <span class="post-date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="placeholder">No related logs yet. Updates coming soon.</p>
      )}
    </section>

    <section class="section">
      <h2>Related Insights</h2>
      {relatedInsights.length > 0 ? (
        <ul class="related-list">
          {relatedInsights.map(post => (
            <li>
              <a href={`/en/insight/${post.slug}`}>{post.data.title}</a>
              <span class="post-date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="placeholder">No related insights yet. Updates coming soon.</p>
      )}
    </section>
  </div>
</PageLayout>

<style>
  .project-detail {
    max-width: 800px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    color: #1976d2;
    text-decoration: none;
    font-weight: 600;
    margin-bottom: 2rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .project-header {
    margin-bottom: 2.5rem;
  }

  .project-header h1 {
    margin-top: 0.75rem;
    font-size: 2rem;
  }

  .project-status {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .status-active {
    background: #e3f2fd;
    color: #1976d2;
  }

  .section {
    margin-bottom: 2.5rem;
  }

  .section h2 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    border-bottom: 1px solid #eee;
    padding-bottom: 0.5rem;
  }

  .section p {
    color: #444;
    line-height: 1.7;
  }

  .placeholder {
    color: #999;
  }

  .related-list {
    padding-left: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .related-list li {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .related-list a {
    color: #1976d2;
    text-decoration: none;
    font-weight: 500;
    line-height: 1.4;
  }

  .related-list a:hover {
    text-decoration: underline;
  }

  .post-date {
    font-size: 0.85rem;
    color: #888;
    white-space: nowrap;
  }
</style>
