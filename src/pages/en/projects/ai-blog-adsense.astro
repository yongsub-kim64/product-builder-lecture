---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const relatedLogs = (await getCollection('en/log', ({ data }) =>
  data.published !== false && data.project_tag === 'AIBlogAdSense'
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const relatedInsights = (await getCollection('en/insight', ({ data }) =>
  data.published !== false && data.project_tag === 'AIBlogAdSense'
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  title="AI Blog / AdSense Experiment"
  description="A content monetization project experimenting with AI-assisted writing, Blogger operation, content structuring, and the AdSense approval process."
>
  <div class="project-detail">

    <a href="/en/projects" class="back-link">← Projects</a>

    <div class="project-header">
      <span class="project-status status-experimental">Monetization Experiment in Progress</span>
      <h1>AI Blog / AdSense Experiment</h1>
      <p class="project-lead">A content monetization project that experiments with and records AI-assisted writing, Blogger operation, content structuring, and the AdSense approval process in a live setting.</p>
    </div>

    <section class="section">
      <h2>Project Overview</h2>
      <p>An external blog (ai60lab.blogspot.com) serves as the actual testing ground — publishing content in collaboration with AI writing tools and directly verifying the AdSense approval preparation process.</p>
      <p>This project is not about duplicating blog content into chulbuji.com. The external blog is where real posts are published and monetization experiments run. chulbuji.com is the hub where experiment goals, operational decisions, structural improvements, and the resulting records and insights are preserved as assets.</p>
    </section>

    <section class="section">
      <h2>Current Status</h2>
      <p>Running a live blog to validate AI writing, featured image creation, SEO checks, Search Console monitoring, and AdSense preparation.</p>
      <p>Current focus: content publishing, indexing, and building the approval foundation. AdSense approval and revenue generation have not yet been confirmed.</p>
    </section>

    <section class="section">
      <h2>Experiment Goals</h2>
      <ul>
        <li>Verify whether consistent blog content production is achievable through AI collaboration</li>
        <li>Build a repeatable operational flow from post publishing through Search Console indexing</li>
        <li>Confirm the content structure and blog practices that meet AdSense approval requirements</li>
        <li>Measure the real-world efficiency and quality of AI writing tools in a live environment</li>
      </ul>
    </section>

    <section class="section">
      <h2>Operational Structure</h2>
      <ul>
        <li><strong>External Blog (Blogger)</strong> — live post publishing and AdSense experiment space</li>
        <li><strong>AI Tools</strong> — writing assistance, featured image creation, SEO review support</li>
        <li><strong>Search Console</strong> — indexing status and search visibility monitoring</li>
        <li><strong>chulbuji.com</strong> — experiment goals, operational decisions, records and insight preservation</li>
      </ul>
    </section>

    <section class="section">
      <h2>The Relationship Between the External Blog and chulbuji.com</h2>
      <p>This project is not about copying or migrating external blog content into chulbuji.com.</p>
      <p>The external blog is the operational space where actual posts are published and AdSense experiments happen. chulbuji.com is where the experiment's origins, the reasoning behind operational decisions, and the lessons learned are recorded. What accumulates here is not the blog content itself, but the process and insights from the experiment.</p>
    </section>

    <section class="section">
      <h2>Key Links</h2>
      <div class="link-group">
        <a href="https://ai60lab.blogspot.com/" class="link-btn link-btn-primary" target="_blank" rel="noopener noreferrer">View Blog Experiment ↗</a>
        <a href="/en/board/" class="link-btn link-btn-secondary">View Operations Board →</a>
      </div>
    </section>

    <section class="section">
      <h2>Next Checkpoints</h2>
      <ul>
        <li>Indexing rate relative to number of published posts</li>
        <li>Search Console impression trends</li>
        <li>AdSense approval criteria fulfillment</li>
        <li>Establishment of a repeatable post publishing workflow</li>
        <li>Correlation between AI writing quality and indexing/impression performance</li>
      </ul>
    </section>

    <section class="section">
      <h2>Related Records</h2>
      {relatedLogs.length > 0 ? (
        <div class="related-group">
          <h3 class="related-label">Log</h3>
          <ul class="related-list">
            {relatedLogs.map(post => (
              <li>
                <a href={`/en/log/${post.slug}`}>{post.data.title}</a>
                <span class="post-date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
              </li>
            ))}
          </ul>
        </div>
      ) : null}
      {relatedInsights.length > 0 ? (
        <div class="related-group">
          <h3 class="related-label">Insight</h3>
          <ul class="related-list">
            {relatedInsights.map(post => (
              <li>
                <a href={`/en/insight/${post.slug}`}>{post.data.title}</a>
                <span class="post-date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
              </li>
            ))}
          </ul>
        </div>
      ) : null}
      {relatedLogs.length === 0 && relatedInsights.length === 0 && (
        <p class="no-records">No records are currently linked to this project.</p>
      )}
    </section>

  </div>
</BaseLayout>

<style>
  .project-detail {
    max-width: 720px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 4rem;
  }

  .back-link {
    display: inline-block;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--primary-color);
  }

  .project-header {
    margin-bottom: 2.5rem;
  }

  .project-status {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.8125rem;
    font-weight: 600;
    margin-bottom: 0.875rem;
  }

  .status-experimental {
    background: #fff3e0;
    color: #e65100;
  }

  .project-header h1 {
    font-size: clamp(1.625rem, 1.25rem + 1.875vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .project-lead {
    font-size: var(--font-size-base);
    line-height: 1.85;
    color: var(--text-muted);
    border-left: 3px solid var(--border-color);
    padding-left: 1rem;
    margin: 0;
    max-width: 100%;
  }

  .section {
    padding-top: 2.25rem;
    border-top: 1px solid var(--border-color);
    margin-bottom: 0;
  }

  .section h2 {
    font-size: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
    font-weight: 700;
    margin-bottom: 0.875rem;
    color: var(--text-color);
    letter-spacing: -0.01em;
  }

  .section > p {
    font-size: var(--font-size-base);
    color: var(--text-color);
    line-height: 1.85;
    margin-bottom: 0.875rem;
    max-width: 100%;
  }

  .section > p:last-child {
    margin-bottom: 0;
  }

  .section ul {
    padding-left: 1.375rem;
    margin: 0.5rem 0 0;
    list-style: disc;
  }

  .section ul li {
    font-size: var(--font-size-base);
    line-height: 1.75;
    margin-bottom: 0.375rem;
    color: var(--text-color);
  }

  .section ul li:last-child {
    margin-bottom: 0;
  }

  /* Link buttons */
  .link-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .link-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.125rem;
    border-radius: 6px;
    font-size: var(--font-size-sm);
    font-weight: 600;
    text-decoration: none;
    min-height: 44px;
    transition: opacity 0.15s, background-color 0.15s;
  }

  .link-btn-primary {
    background: var(--primary-color);
    color: white;
  }

  .link-btn-primary:hover {
    opacity: 0.88;
    color: white;
  }

  .link-btn-secondary {
    border: 1px solid var(--border-color);
    color: var(--text-color);
    background: white;
  }

  .link-btn-secondary:hover {
    border-color: var(--primary-color);
    color: var(--primary-color);
    background: #f7f8ff;
  }

  /* Related records */
  .related-group {
    margin-bottom: 1.25rem;
  }

  .related-group:last-child {
    margin-bottom: 0;
  }

  .related-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
    letter-spacing: 0.04em;
  }

  .related-list {
    padding-left: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin: 0;
  }

  .related-list li {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin: 0;
  }

  .related-list a {
    color: var(--primary-color);
    text-decoration: none;
    font-size: var(--font-size-base);
    font-weight: 500;
    line-height: 1.4;
  }

  .related-list a:hover {
    text-decoration: underline;
  }

  .post-date {
    font-size: 0.8125rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .no-records {
    font-size: var(--font-size-sm);
    color: var(--text-muted);
    margin: 0;
  }

  @media (max-width: 480px) {
    .project-detail {
      padding: 2rem 1rem 3rem;
    }

    .link-group {
      flex-direction: column;
    }

    .link-btn {
      justify-content: center;
    }
  }
</style>
