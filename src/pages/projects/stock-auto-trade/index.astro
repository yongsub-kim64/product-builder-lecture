---
import PageLayout from '../../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const relatedLogs = (await getCollection('ko/log', ({ data }) =>
  data.published !== false && data.project_tag === '자동매매'
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const relatedInsights = (await getCollection('ko/insight', ({ data }) =>
  data.published !== false && data.project_tag === '자동매매'
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<PageLayout title="AI 자동매매 실험" description="AI와 함께 500만원으로 자동매매 시스템을 직접 만들고 운용하는 실험. 코드 한 줄 없이, 규칙 엔진과 AI 보조로 실제 자본을 운용하는 경험을 기록한다.">
  <div class="project-detail">
    <a href="/projects" class="back-link">← 프로젝트 목록</a>

    <div class="project-header">
      <span class="project-status status-active">운영 중</span>
      <h1>AI 자동매매 실험</h1>
      <p class="project-meta">현재 버전: <strong>v1.1</strong> · 최근 업데이트: <strong>2026-04-10</strong></p>
    </div>

    <section class="section">
      <h2>개요</h2>
      <p>AI와 함께 500만원으로 자동매매 시스템을 직접 만들고 운용하는 실험. 성공을 장담하지 않는다. 배우면서 만드는 중이다.</p>
    </section>

    <section class="section">
      <h2>왜 시작했나</h2>
      <p>반도체 엔지니어 34년. 시스템을 설계하고 검증하는 사고방식이 몸에 배어 있다. 그 감각을 금융 자동화에 적용해보고 싶었다.</p>
      <p>목적은 수익이 아니다. "AI가 실제 자본을 운용하는 시스템을 내 손으로 만드는 경험" 자체가 목적이다.</p>
    </section>

    <section class="section">
      <h2>시스템 구조</h2>
      <ul>
        <li>이동평균·RSI 기반 <strong>규칙 엔진</strong>이 매매 결정</li>
        <li>AI는 분석·리포트 보조 역할 (판단하지 않음)</li>
        <li>텔레그램으로 실시간 매매 알림 수신</li>
        <li>모의투자 2주 검증 후 실계좌 전환 예정</li>
        <li>장기 실행 스케줄러 구조로 운영되며, 코드 수정 시 SOP에 따라 프로세스를 재시작하고 반영 여부를 확인한다.</li>
      </ul>
    </section>

    <section class="section">
      <h2>현재 좌표</h2>
      <p><strong>MVP 안정화 완료 → 모의투자 실주문 검증 단계 진입</strong></p>
      <p>단순히 돌아가는 시스템을 만드는 것에서, 실제로 운영 가능한 구조를 갖추는 것으로 목표가 바뀌었다. 이번 작업은 그 전환점이었다.</p>
    </section>

    <section class="section">
      <h2>2026.04.10 업데이트 — 실전급 구조 정비 완료</h2>
      <p>코드 몇 줄을 고친 게 아니다. 자동매매 시스템을 안정적으로 운영할 수 있는 구조를 만드는 작업이었다. 방향과 현황 판단은 메타철부지가, 실제 코드 분석·수정·검증은 개발 전문 AI와 Claude Code가 맡는 협업 구조로 전환했다. 어제 저녁 두 시간 안에 총 11개 항목이 정비됐다.</p>

      <h3>✅ 안정성 정비</h3>
      <table class="update-table">
        <thead><tr><th>항목</th><th>내용</th></tr></thead>
        <tbody>
          <tr><td>예수금 필드 교체</td><td>잘못된 값 참조 → 정확한 필드로 교체</td></tr>
          <tr><td>API 재시도 로직</td><td>호출 실패 시 재시도 구조 추가</td></tr>
          <tr><td>중복 매수 방지</td><td>동일 종목 중복 매수 차단</td></tr>
          <tr><td>중복 기동 방지</td><td>프로세스 중복 실행 방지</td></tr>
          <tr><td>hold_days 버그 수정</td><td>보유 일수 계산 오류 수정</td></tr>
          <tr><td>IS_PAPER 안전장치</td><td>모의/실투자 혼용 방지</td></tr>
        </tbody>
      </table>

      <h3>✅ 전략 정비</h3>
      <table class="update-table">
        <thead><tr><th>항목</th><th>내용</th></tr></thead>
        <tbody>
          <tr><td>RSI Wilder 방식 적용</td><td>기존 방식 → Wilder 방식으로 전환</td></tr>
          <tr><td>RSI 범위 조정</td><td>40~65로 조정</td></tr>
          <tr><td>MA20 이격도 제한</td><td>5% 이내 조건 추가</td></tr>
          <tr><td>투자 비중 확대</td><td>20%, 최대 100만 원</td></tr>
          <tr><td>트레일링 스탑 도입</td><td>수익 구간 보호 구조 최초 적용</td></tr>
        </tbody>
      </table>

      <h3>✅ 운영 구조 정비</h3>
      <table class="update-table">
        <thead><tr><th>항목</th><th>내용</th></tr></thead>
        <tbody>
          <tr><td>매수 스캔 구조</td><td>장전 1회 + 장중 4회</td></tr>
          <tr><td>DRY RUN / LIVE 구분</td><td>로그·텔레그램에서 명확히 분리</td></tr>
          <tr><td>장후 요약 구조</td><td>하루 운영 결과 자동 정리</td></tr>
          <tr><td>검증 체크포인트</td><td>월요일 첫 운영 기준 항목 정리</td></tr>
        </tbody>
      </table>
    </section>

    <section class="section">
      <h2>운영 방식 변화</h2>
      <p>이번을 기점으로 프로젝트 운영 구조가 정리됐다.</p>
      <ul>
        <li><strong>메타철부지와</strong> — 방향 판단, 현황 해석, 전략 우선순위 결정</li>
        <li><strong>개발 전문 AI와</strong> — 코드 분석, 수정, 검증, 구현</li>
      </ul>
      <p>직접 디버깅 구조를 하나씩 따라가던 방식에서, 방향과 판단에 집중하는 방식으로. 역할이 나뉘니 속도가 달라졌다.</p>
    </section>

    <section class="section">
      <h2>다음 검증 일정</h2>
      <p><strong>2026.04.14 (월) — 모의투자 실주문 첫 운영 검증</strong></p>
      <ul>
        <li>시스템이 실제 장에서 어떻게 움직이는지 첫 확인</li>
        <li>매수 스캔 구조, 트레일링 스탑, 로그 구분 실전 검증</li>
        <li>예상치 못한 동작 발생 시 즉시 기록 후 개선</li>
      </ul>
    </section>

    <section class="section">
      <h2>이후 로드맵</h2>
      <p>정비가 끝났다고 완성된 게 아니다. 첫 운영 결과를 보고 다음을 결정한다.</p>
      <ul>
        <li>거래량 급증 조건 추가 검토</li>
        <li>종목 유니버스 .env 이관</li>
        <li>섹터 분산 구조 설계</li>
        <li>매수 우선순위 점수화</li>
        <li>실계좌 전환 SOP 수립</li>
      </ul>
    </section>

    <section class="section">
      <h2>업데이트 이력</h2>
      <ul>
        <li><strong>2026-04-10</strong> — 실전급 구조 정비 완료: 예수금 필드 교체 / API 재시도 로직 / 중복 매수·기동 방지 / hold_days 버그 수정 / IS_PAPER 안전장치 / RSI Wilder 방식 전환 / RSI 범위 40~65 / MA20 이격도 5% 제한 / 투자 비중 20% 최대 100만 원 / 트레일링 스탑 도입 / 운영 협업 구조 재설계</li>
        <li><strong>2026-04-09</strong> — Python 모듈 캐시 이슈 확인 — 코드 수정 후 스케줄러 재시작 없이는 변경 사항이 반영되지 않음을 실운영에서 확인. is_market_ok()에 진단 로그 추가 / 모의투자 환경의 MA60 미충족 시 종가 > MA20 기준 폴백 반영 / check_buy_signal()에 동일 기준 폴백 적용 / BUY 사유 포맷 오류 수정 / DRY_RUN 기준 매수 사이클 복구 확인 / 스케줄러 재시작 SOP 문서 신규 작성</li>
        <li><strong>v1.1</strong> · 2026-04-08 — 시장 레짐 2중 필터 / 거래대금 100억 필터 / 매도 조건 IMMEDIATE·NEXT_OPEN 분기 / 당일 재매수 금지 / 로그 체계 정리</li>
        <li><strong>v1.0</strong> · 2026-04-07 — KIS API 연동, 규칙 엔진, 텔레그램 알림, 스케줄러 MVP 완성</li>
      </ul>
    </section>

    <section class="section">
      <h2>관련 기록 (Log)</h2>
      {relatedLogs.length > 0 ? (
        <ul class="related-list">
          {relatedLogs.map(post => (
            <li>
              <a href={`/log/${post.slug}`}>{post.data.title}</a>
              <span class="post-date">{post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="placeholder">관련 기록이 아직 없습니다.</p>
      )}
    </section>

    <section class="section">
      <h2>관련 인사이트 (Insight)</h2>
      {relatedInsights.length > 0 ? (
        <ul class="related-list">
          {relatedInsights.map(post => (
            <li>
              <a href={`/insight/${post.slug}`}>{post.data.title}</a>
              <span class="post-date">{post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="placeholder">관련 인사이트가 아직 없습니다. Insight 파일에 <code>project_tag: "자동매매"</code>를 추가하면 자동으로 연결됩니다.</p>
      )}
    </section>
  </div>
</PageLayout>

<style>
  .project-detail {
    max-width: 800px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    color: #1976d2;
    text-decoration: none;
    font-weight: 600;
    margin-bottom: 2rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .project-header {
    margin-bottom: 2.5rem;
  }

  .project-header h1 {
    margin-top: 0.75rem;
    font-size: 2rem;
  }

  .project-status {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .status-experimental {
    background-color: #fce4ec;
    color: #c62828;
  }

  .status-active {
    background-color: #e8f5e9;
    color: #2e7d32;
  }

  .project-meta {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: #666;
  }

  .section {
    margin-bottom: 2.5rem;
  }

  .section h2 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    border-bottom: 1px solid #eee;
    padding-bottom: 0.5rem;
  }

  .section p {
    color: #444;
    line-height: 1.7;
  }

  .placeholder {
    color: #999;
  }

  .section ul {
    padding-left: 1.25rem;
    color: #444;
    line-height: 1.9;
  }

  .section ul a {
    color: #1976d2;
    text-decoration: none;
  }

  .section ul a:hover {
    text-decoration: underline;
  }

  .related-list {
    padding-left: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .related-list li {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .related-list a {
    color: #1976d2;
    text-decoration: none;
    font-weight: 500;
    line-height: 1.4;
  }

  .related-list a:hover {
    text-decoration: underline;
  }

  .post-date {
    font-size: 0.85rem;
    color: #888;
    white-space: nowrap;
  }

  .section h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
    color: #333;
  }

  .update-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    color: #444;
  }

  .update-table th {
    background-color: #f5f5f5;
    text-align: left;
    padding: 0.5rem 0.75rem;
    border: 1px solid #ddd;
    font-weight: 600;
  }

  .update-table td {
    padding: 0.5rem 0.75rem;
    border: 1px solid #ddd;
    line-height: 1.6;
  }

  .update-table tr:nth-child(even) td {
    background-color: #fafafa;
  }
</style>
