---
import PageLayout from '../../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const relatedLogs = (await getCollection('ko/log', ({ data }) =>
  data.published !== false && data.project_tag === '자동매매'
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const relatedInsights = (await getCollection('ko/insight', ({ data }) =>
  data.published !== false && data.project_tag === '자동매매'
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<PageLayout title="AI 자동매매 실험" description="AI와 함께 500만원으로 자동매매 시스템을 직접 만들고 운용하는 실험. 코드 한 줄 없이, 규칙 엔진과 AI 보조로 실제 자본을 운용하는 경험을 기록한다.">
  <div class="project-detail">
    <a href="/projects" class="back-link">← 프로젝트 목록</a>

    <div class="project-header">
      <span class="project-status status-active">🟢 실전 운영 중</span>
      <h1>AI 자동매매 실험</h1>
      <p class="project-meta">현재 버전: <strong>v1.2</strong> · 최근 업데이트: <strong>2026-04-14</strong></p>
    </div>

    <section class="section">
      <h2>개요</h2>
      <p>AI와 함께 500만원으로 자동매매 시스템을 직접 만들고 운용하는 실험.<br>
      코딩을 모르는 운영자가 판단을 맡고, AI가 실행을 맡는 협업 구조가 핵심이다.</p>
      <p>목적은 수익이 아니다.<br>
      "AI가 실제 자본을 운용하는 시스템을 내 손으로 만드는 경험"이 이 프로젝트의 목적이다.</p>
    </section>

    <section class="section">
      <h2>현재 좌표</h2>
      <p>2026-04-14, 첫 실주문 체결. DRY_RUN에서 실전으로 전환 완료.</p>
    </section>

    <section class="section">
      <h2>협업 구조</h2>
      <table class="update-table">
        <thead><tr><th>역할</th><th>담당</th></tr></thead>
        <tbody>
          <tr><td>전략 방향 + 상황 판단</td><td>메타철부지 (GPT)</td></tr>
          <tr><td>코드 분석 + 수정 실행</td><td>Claude Code</td></tr>
          <tr><td>방향 설정 + 최종 판단</td><td>운영자 (철부지)</td></tr>
        </tbody>
      </table>
    </section>

    <section class="section">
      <h2>핵심 전략 (현재 적용)</h2>
      <table class="update-table">
        <thead><tr><th>항목</th><th>기준</th></tr></thead>
        <tbody>
          <tr><td>매수 신호</td><td>RSI(Wilder) 40~65</td></tr>
          <tr><td>추세 필터</td><td>MA20 이격도 5% 이내</td></tr>
          <tr><td>투자 비중</td><td>종목당 20% / 최대 100만원</td></tr>
          <tr><td>익절</td><td>+6% 고정 또는 트레일링 스탑</td></tr>
          <tr><td>트레일링 스탑</td><td>+4% 활성화 / 고점 대비 -2% 매도</td></tr>
          <tr><td>손절</td><td>-3%</td></tr>
          <tr><td>당일 재매수</td><td>차단</td></tr>
        </tbody>
      </table>
    </section>

    <section class="section">
      <h2>2026.04.14 업데이트 — 실전 전환 완료</h2>
      <p>DRY_RUN 검증을 마치고 실전으로 전환했다. 전환 전 오전에만 수정 3건이 있었고, 오후에 운영 보완까지 완료했다.</p>

      <h3>✅ STEP 6 — RSI Wilder 방식 교체 + MA20 이격도 5% 제한</h3>
      <table class="update-table">
        <thead><tr><th>항목</th><th>내용</th></tr></thead>
        <tbody>
          <tr><td>RSI 방식 교체</td><td>기존 방식 → Wilder 평활화로 전환</td></tr>
          <tr><td>MA20 이격도 제한</td><td>5% 초과 시 매수 차단 (고점 추격 방지)</td></tr>
        </tbody>
      </table>

      <h3>✅ STEP 7 — 트레일링 스탑 도입</h3>
      <table class="update-table">
        <thead><tr><th>항목</th><th>내용</th></tr></thead>
        <tbody>
          <tr><td>활성화 조건</td><td>수익률 +4% 도달 시 트레일링 활성화</td></tr>
          <tr><td>매도 조건</td><td>고점 대비 -2% 하락 시 매도</td></tr>
        </tbody>
      </table>

      <h3>✅ STEP 8 — 예수금 폴백 로직 추가</h3>
      <table class="update-table">
        <thead><tr><th>항목</th><th>내용</th></tr></thead>
        <tbody>
          <tr><td>폴백 처리</td><td>API 응답 이상 시 예수금 조회 실패 케이스 처리</td></tr>
        </tbody>
      </table>

      <h3>✅ STEP 9 — 운영 보완</h3>
      <table class="update-table">
        <thead><tr><th>항목</th><th>내용</th></tr></thead>
        <tbody>
          <tr><td>트레일링 활성화 로그</td><td>어떤 종목이 기준선 도달했는지 실시간 확인</td></tr>
          <tr><td>장후 텔레그램 명세</td><td>마감 후 보유종목 현황 자동 발송</td></tr>
          <tr><td>작업스케줄러 --live 등록</td><td>내일부터 자동 실거래 시작</td></tr>
        </tbody>
      </table>

      <p><strong>오늘 장 마감 기준:</strong> 삼성전자 +1.60% / 카카오 -0.41% / 총 평가금액 10,002,370원</p>
    </section>

    <section class="section">
      <h2>2026.04.10 업데이트 — 실전급 구조 정비 완료</h2>
      <p>코드 몇 줄을 고친 게 아니다. 자동매매 시스템을 안정적으로 운영할 수 있는 구조를 만드는 작업이었다. 방향과 현황 판단은 메타철부지가, 실제 코드 분석·수정·검증은 개발 전문 AI와 Claude Code가 맡는 협업 구조로 전환했다. 어제 저녁 두 시간 안에 총 11개 항목이 정비됐다.</p>

      <h3>✅ 안정성 정비</h3>
      <table class="update-table">
        <thead><tr><th>항목</th><th>내용</th></tr></thead>
        <tbody>
          <tr><td>예수금 필드 교체</td><td>잘못된 값 참조 → 정확한 필드로 교체</td></tr>
          <tr><td>API 재시도 로직</td><td>호출 실패 시 재시도 구조 추가</td></tr>
          <tr><td>중복 매수 방지</td><td>동일 종목 중복 매수 차단</td></tr>
          <tr><td>중복 기동 방지</td><td>프로세스 중복 실행 방지</td></tr>
          <tr><td>hold_days 버그 수정</td><td>보유 일수 계산 오류 수정</td></tr>
          <tr><td>IS_PAPER 안전장치</td><td>모의/실투자 혼용 방지</td></tr>
        </tbody>
      </table>

      <h3>✅ 전략 정비</h3>
      <table class="update-table">
        <thead><tr><th>항목</th><th>내용</th></tr></thead>
        <tbody>
          <tr><td>RSI Wilder 방식 적용</td><td>기존 방식 → Wilder 방식으로 전환</td></tr>
          <tr><td>RSI 범위 조정</td><td>40~65로 조정</td></tr>
          <tr><td>MA20 이격도 제한</td><td>5% 이내 조건 추가</td></tr>
          <tr><td>투자 비중 확대</td><td>20%, 최대 100만 원</td></tr>
          <tr><td>트레일링 스탑 도입</td><td>수익 구간 보호 구조 최초 적용</td></tr>
        </tbody>
      </table>

      <h3>✅ 운영 구조 정비</h3>
      <table class="update-table">
        <thead><tr><th>항목</th><th>내용</th></tr></thead>
        <tbody>
          <tr><td>매수 스캔 구조</td><td>장전 1회 + 장중 4회</td></tr>
          <tr><td>DRY RUN / LIVE 구분</td><td>로그·텔레그램에서 명확히 분리</td></tr>
          <tr><td>장후 요약 구조</td><td>하루 운영 결과 자동 정리</td></tr>
          <tr><td>검증 체크포인트</td><td>월요일 첫 운영 기준 항목 정리</td></tr>
        </tbody>
      </table>
    </section>

    <section class="section">
      <h2>운영 방식 변화</h2>
      <p>이번을 기점으로 프로젝트 운영 구조가 정리됐다.</p>
      <ul>
        <li><strong>메타철부지와</strong> — 방향 판단, 현황 해석, 전략 우선순위 결정</li>
        <li><strong>개발 전문 AI와</strong> — 코드 분석, 수정, 검증, 구현</li>
      </ul>
      <p>직접 디버깅 구조를 하나씩 따라가던 방식에서, 방향과 판단에 집중하는 방식으로. 역할이 나뉘니 속도가 달라졌다.</p>
    </section>

    <section class="section">
      <h2>다음 예정</h2>
      <ul>
        <li>STEP 10: 거래량 급증 조건 추가</li>
        <li>STEP 11: 종목 유니버스 .env 이관</li>
        <li>섹터 분산 종목 추가 검토</li>
        <li>실계좌 전환 SOP 수립</li>
      </ul>
    </section>

    <section class="section">
      <h2>업데이트 이력</h2>
      <ul>
        <li><strong>2026-04-14 · v1.2</strong> — 실전 전환 완료. STEP 6~9: 트레일링 스탑 고도화 / 예수금 폴백 / 장후 텔레그램 명세 / 첫 실주문 체결 (카카오 20주 @ 48,350원)</li>
        <li><strong>2026-04-10</strong> — 실전급 구조 정비 완료: 예수금 필드 교체 / API 재시도 로직 / 중복 매수·기동 방지 / hold_days 버그 수정 / IS_PAPER 안전장치 / RSI Wilder 방식 전환 / RSI 범위 40~65 / MA20 이격도 5% 제한 / 투자 비중 20% 최대 100만 원 / 트레일링 스탑 도입 / 운영 협업 구조 재설계</li>
        <li><strong>2026-04-09</strong> — Python 모듈 캐시 이슈 확인 — 코드 수정 후 스케줄러 재시작 없이는 변경 사항이 반영되지 않음을 실운영에서 확인. is_market_ok()에 진단 로그 추가 / 모의투자 환경의 MA60 미충족 시 종가 > MA20 기준 폴백 반영 / check_buy_signal()에 동일 기준 폴백 적용 / BUY 사유 포맷 오류 수정 / DRY_RUN 기준 매수 사이클 복구 확인 / 스케줄러 재시작 SOP 문서 신규 작성</li>
        <li><strong>v1.1</strong> · 2026-04-08 — 시장 레짐 2중 필터 / 거래대금 100억 필터 / 매도 조건 IMMEDIATE·NEXT_OPEN 분기 / 당일 재매수 금지 / 로그 체계 정리</li>
        <li><strong>v1.0</strong> · 2026-04-07 — KIS API 연동, 규칙 엔진, 텔레그램 알림, 스케줄러 MVP 완성</li>
      </ul>
    </section>

    <section class="section">
      <h2>관련 기록 (Log)</h2>
      {relatedLogs.length > 0 ? (
        <ul class="related-list">
          {relatedLogs.map(post => (
            <li>
              <a href={`/log/${post.slug}`}>{post.data.title}</a>
              <span class="post-date">{post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="placeholder">관련 기록이 아직 없습니다.</p>
      )}
    </section>

    <section class="section">
      <h2>관련 인사이트 (Insight)</h2>
      {relatedInsights.length > 0 ? (
        <ul class="related-list">
          {relatedInsights.map(post => (
            <li>
              <a href={`/insight/${post.slug}`}>{post.data.title}</a>
              <span class="post-date">{post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="placeholder">관련 인사이트가 아직 없습니다. Insight 파일에 <code>project_tag: "자동매매"</code>를 추가하면 자동으로 연결됩니다.</p>
      )}
    </section>
  </div>
</PageLayout>

