    text-decoration: underline;
  }

  .project-header {
    margin-bottom: 2.5rem;
  }

  .project-header h1 {
    margin-top: 0.75rem;
    font-size: 2rem;
  }

  .project-status {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .status-experimental {
    background-color: #fce4ec;
    color: #c62828;
  }

  .status-active {
    background-color: #e8f5e9;
    color: #2e7d32;
  }

  .project-meta {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: #666;
  }

