---
import PageLayout from '../../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const relatedLogs = (await getCollection('ko/log', ({ data }) =>
  data.published !== false && data.project_tag === '자동매매'
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const relatedInsights = (await getCollection('ko/insight', ({ data }) =>
  data.published !== false && data.project_tag === '자동매매'
)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<PageLayout title="AI 자동매매 실험" description="AI와 함께 500만원으로 자동매매 시스템을 직접 만들고 운용하는 실험. 코드 한 줄 없이, 규칙 엔진과 AI 보조로 실제 자본을 운용하는 경험을 기록한다.">
  <div class="project-detail">
    <a href="/projects" class="back-link">← 프로젝트 목록</a>

    <div class="project-header">
      <span class="project-status status-active">🟢 실전 운영 중</span>
      <h1>AI 자동매매 실험</h1>
      <p class="project-meta">현재 버전: <strong>v1.4</strong> · 최근 업데이트: <strong>2026-04-24</strong></p>
    </div>

    <section class="section">
      <h2>개요</h2>
      <p>AI와 함께 500만원으로 자동매매 시스템을 직접 만들고 운용하는 실험.<br>
      코딩을 모르는 운영자가 판단을 맡고, AI가 실행을 맡는 협업 구조가 핵심이다.</p>
      <p>목적은 수익이 아니다.<br>
      "AI가 실제 자본을 운용하는 시스템을 내 손으로 만드는 경험"이 이 프로젝트의 목적이다.</p>
    </section>

    <section class="section">
      <h2>현재 좌표</h2>
      <p>🟢 <strong>실계좌 운영 중</strong> — 버그 5건 수정·전략 6건 개선 완료(2026-04-24). 예수금 필드 오참조(ord_psbl_cash_amt 교체), KT 매도 예약 중복 18건 제거. 레짐 판단 5조건 점수제 전환 + 2일 연속 확인 안정화 + 현금 비율(강세 20%/중립 35%/약세 60%) 적용. 마감 평가잔고 4,890,000원. (2026-04-24 기준)</p>
    </section>

    <section class="section">
      <h2>협업 구조</h2>
      <table class="update-table">
        <thead><tr><th>역할</th><th>담당</th></tr></thead>
        <tbody>
          <tr><td>전략 방향 + 상황 판단</td><td>메타철부지 (GPT)</td></tr>
          <tr><td>코드 분석 + 수정 실행</td><td>Claude Code</td></tr>
          <tr><td>방향 설정 + 최종 판단</td><td>운영자 (철부지)</td></tr>
        </tbody>
      </table>
    </section>

    <section class="section">
      <h2>핵심 전략 (현재 적용)</h2>
      <table class="update-table">
        <thead><tr><th>항목</th><th>기준</th></tr></thead>
        <tbody>
          <tr><td>매수 신호</td><td>RSI(Wilder) 40~65</td></tr>
          <tr><td>추세 필터</td><td>MA20 이격도 — 대형주 14% / 일반 7% 이내 (버퍼 구간 적용)</td></tr>
          <tr><td>투자 비중</td><td>종목당 20% / 최대 100만원 · 최대 5종목</td></tr>
          <tr><td>최대 투자</td><td>500만원 (예수금 50%)</td></tr>
          <tr><td>현금 보유 비율</td><td>강세장 20% / 중립장 35% / 약세장 60% (총자산 연동)</td></tr>
          <tr><td>레짐 판단</td><td>5가지 조건 점수제 · 2일 연속 동일 신호 → 레짐 전환</td></tr>
          <tr><td>매수 스캔</td><td>3회/일 (10:00 / 13:00 / 14:00)</td></tr>
          <tr><td>익절</td><td>+6% 고정 또는 트레일링 스탑</td></tr>
          <tr><td>트레일링 스탑</td><td>+4% 활성화 / 고점 대비 -2% 매도</td></tr>
          <tr><td>손절</td><td>-3%</td></tr>
          <tr><td>종목 유니버스</td><td>20개 (섹터 분산)</td></tr>
          <tr><td>당일 재매수</td><td>차단</td></tr>
        </tbody>
      </table>
    </section>

    <section class="section">
      <h2>업데이트 이력</h2>
      <ul>
        <li><strong>2026-04-24 · v1.4</strong> — 버그 5건 수정·전략 6건 개선. 예수금 필드 오참조(prvs_rcdl_excc_amt→ord_psbl_cash_amt) 수정으로 주문 정상화. KT PENDING_SELL 중복 18건 제거 + 중복 방지 로직 추가. MA20 이격 기준 종목 특성별 분리(대형주 14%/일반 7%), 매수·매도 사이 버퍼 구간 추가. 레짐 판단 전일 KOSPI 종가 단일 기준→5조건 점수제 전환, 2일 연속 확인 안정화, 총자산 연동 현금 비율(강세 20%/중립 35%/약세 60%) 적용. 실현손익 -93,000원(기아·KT 손절). 주문 성공 4건. 마감 평가잔고 4,890,000원.</li>
        <li><strong>2026-04-22</strong> — 실계좌 3일차. 손절 2건 집행(KB금융·카카오, 합계 -61,800원). MA60 필터 하락추세 3종목(NAVER·기아·현대차) 정상 차단 — 4/21 API 교체 첫 실전 검증 완료(65건, MA20+MA60 정상). 예산 안전마진(safe_budget×0.95) 부분 검증: 13:00 성공/14:00 재실패. KT 신규 진입. 마감 평가잔고 4,906,290원.</li>
        <li><strong>2026-04-21</strong> — MA60 API 교체 완료. inquire-daily-price(30건 고정) → inquire-daily-itemchartprice(65건)로 교체. 4/22 실전에서 하락추세 차단 검증.</li>
        <li><strong>2026-04-20</strong> — 실계좌 첫 운영일. 버그 2건 수정(토큰 캐시 오염·MA60=None 시 MA20 폴백). 5종목 첫 체결(카카오·기아·KB금융·신한지주·NAVER), 투자금 4,690,300원. 잔여 예수금 305,970원. 장마감 평가손익 -54,030원(-1.08%), 전량 HOLD. 텔레그램·데이터 익스포트 정상.</li>
        <li><strong>2026-04-17 · v1.3</strong> — 1주일 모의투자 완료 및 실계좌 전환 결정. 버그 4건 수정(매수금액 손실 인식 / 손실 한도 하드코딩 / 예수금 고착 / 계좌번호 형식 오류). 카카오 트레일링 스탑 발동(+3.01%, +30,060원). 주간 실현손익 +45,060원(+0.58%). 실계좌 API 연결 확인.</li>
        <li><strong>2026-04-16</strong> — STEP 11·12 완료. 매수 스캔 4회→3회 최적화. 종목 유니버스 5→20개 확대. 이격도 5%→7% 완화. 최대 보유 3→5종목.</li>
        <li><strong>2026-04-15</strong> — STEP 10 완료. lock 파일 자동복구(psutil PID 검증) 도입. 트레일링 스탑 첫 실전 발동. 삼성전자 +3.57% 자동 매도. 실현손익 +15,000원.</li>
        <li><strong>2026-04-14</strong> — 실전 전환 완료. 트레일링 스탑 고도화, 예수금 폴백, 장후 텔레그램 명세 추가. 첫 실주문 체결 (카카오 20주 @ 48,350원)</li>
        <li><strong>2026-04-10</strong> — 실전급 구조 정비. 예수금 필드 교체 / API 재시도 / 중복 매수·기동 방지 / hold_days 수정 / IS_PAPER 안전장치</li>
        <li><strong>2026-04-09</strong> — Python 모듈 캐시 이슈 확인 및 매수 사이클 복구. 스케줄러 재시작 SOP 신규 작성</li>
        <li><strong>2026-04-08 · v1.1</strong> — 시장 레짐 2중 필터 / 거래대금 필터 / 매도 조건 분기 / 당일 재매수 금지 / 로그 체계 정리</li>
        <li><strong>2026-04-07 · v1.0</strong> — KIS API 연동, 규칙 엔진, 텔레그램 알림, 스케줄러 MVP 완성</li>
      </ul>
    </section>

    <section class="section">
      <h2>다음 예정</h2>
      <ul>
        <li>다음 주 월요일 08:50 장전 사이클 — BULL 신호 기록 여부 확인 (레짐 점수제 첫 실전 검증)</li>
        <li>다음 주 월요일 10:00 스캔 — 삼성전자 이격 기준 변경 후 조건 통과 및 매수 실행 여부</li>
        <li>종목별 승률 통계 집계 (2주 후)</li>
        <li>거래량 급증 조건 추가 검토</li>
        <li>월 1회 종목 리밸런싱 기준 수립</li>
      </ul>
    </section>

    <section class="section">
      <h2>관련 기록 (Log)</h2>
      {relatedLogs.length > 0 ? (
        <ul class="related-list">
          {relatedLogs.map(post => (
            <li>
              <a href={`/log/${post.slug}`}>{post.data.title}</a>
              <span class="post-date">{post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="placeholder">관련 기록이 아직 없습니다.</p>
      )}
    </section>

    <section class="section">
      <h2>관련 인사이트 (Insight)</h2>
      {relatedInsights.length > 0 ? (
        <ul class="related-list">
          {relatedInsights.map(post => (
            <li>
              <a href={`/insight/${post.slug}`}>{post.data.title}</a>
              <span class="post-date">{post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="placeholder">관련 인사이트가 아직 없습니다. Insight 파일에 <code>project_tag: "자동매매"</code>를 추가하면 자동으로 연결됩니다.</p>
      )}
    </section>
  </div>
</PageLayout>

<style>
  .project-detail {
    max-width: 800px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    color: #1976d2;
    text-decoration: none;
    font-weight: 600;
    margin-bottom: 2rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .project-header {
    margin-bottom: 2.5rem;
  }

  .project-header h1 {
    margin-top: 0.75rem;
    font-size: 2rem;
  }

  .project-status {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .status-experimental {
    background-color: #fce4ec;
    color: #c62828;
  }

  .status-active {
    background-color: #e8f5e9;
    color: #2e7d32;
  }

  .project-meta {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: #666;
  }

  .section {
    margin-bottom: 2.5rem;
  }

  .section h2 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    border-bottom: 1px solid #eee;
    padding-bottom: 0.5rem;
  }

  .section p {
    color: #444;
    line-height: 1.7;
  }

  .placeholder {
    color: #999;
  }

  .section ul {
    padding-left: 1.25rem;
    color: #444;
    line-height: 1.9;
  }

  .section ul a {
    color: #1976d2;
    text-decoration: none;
  }

  .section ul a:hover {
    text-decoration: underline;
  }

  .related-list {
    padding-left: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .related-list li {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .related-list a {
    color: #1976d2;
    text-decoration: none;
    font-weight: 500;
    line-height: 1.4;
  }

  .related-list a:hover {
    text-decoration: underline;
  }

  .post-date {
    font-size: 0.85rem;
    color: #888;
    white-space: nowrap;
  }

  .section h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
    color: #333;
  }

  .update-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1rem;
    font-size: 0.9rem;
    color: #444;
  }

  .update-table th {
    background-color: #f5f5f5;
    text-align: left;
    padding: 0.5rem 0.75rem;
    border: 1px solid #ddd;
    font-weight: 600;
  }

  .update-table td {
    padding: 0.5rem 0.75rem;
    border: 1px solid #ddd;
    line-height: 1.6;
  }

  .update-table tr:nth-child(even) td {
    background-color: #fafafa;
  }
</style>
