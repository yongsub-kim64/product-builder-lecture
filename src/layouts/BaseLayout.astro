---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { getLangFromUrl } from '../utils/i18n';

interface Props {
  title: string;
  description?: string;
  titleOverride?: string;
  noindex?: boolean;
  ogImage?: string;
}

const { title, description, titleOverride, noindex, ogImage } = Astro.props;
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).toString() : undefined;
const lang = getLangFromUrl(Astro.url);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const metaTitle = titleOverride ?? `${title} | chulbuji`;
const ogTitle = titleOverride ?? title;

// --- hreflang ---
const pathname = Astro.url.pathname;
const is404 = pathname === '/404' || pathname === '/en/404';
const isEnPage = pathname.startsWith('/en/') || pathname === '/en';
const koPath = isEnPage ? (pathname.slice(3) || '/') : pathname;
const koHref = `https://chulbuji.com${koPath}`;
const enHref = `https://chulbuji.com/en${koPath}`;

const enPageFiles = import.meta.glob('/src/pages/en/**/*.astro');
const koPageFiles = import.meta.glob(['/src/pages/**/*.astro', '!/src/pages/en/**/*.astro']);
const enContentFiles = import.meta.glob('/src/content/en/**/*.md');
const koContentFiles = import.meta.glob('/src/content/ko/**/*.md');

function hasCounterpart(
  pageFiles: Record<string, unknown>,
  contentFiles: Record<string, unknown>,
  pagePrefix: string,
  contentPrefix: string
): boolean {
  const clean = koPath.replace(/\/$/, '') || '/';
  const pageCandidates = clean === '/'
    ? [`${pagePrefix}/index.astro`]
    : [`${pagePrefix}${clean}/index.astro`, `${pagePrefix}${clean}.astro`];
  if (pageCandidates.some(f => f in pageFiles)) return true;
  const segs = clean.split('/').filter(Boolean);
  if (segs.length >= 2) {
    const key = `${contentPrefix}/${segs[0]}/${segs.slice(1).join('/')}.md`;
    if (key in contentFiles) return true;
  }
  return false;
}

const showEnAlternate = !is404 && !isEnPage &&
  hasCounterpart(enPageFiles, enContentFiles, '/src/pages/en', '/src/content/en');
const showKoAlternate = !is404 && isEnPage &&
  hasCounterpart(koPageFiles, koContentFiles, '/src/pages', '/src/content/ko');
const xdefaultHref = (!isEnPage || showKoAlternate) ? koHref : enHref;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="canonical" href={canonicalURL} />
  
  <title>{metaTitle}</title>
  {noindex && <meta name="robots" content="noindex, follow" />}
  {description && <meta name="description" content={description} />}

  <!-- Open Graph -->
  <meta property="og:title" content={ogTitle} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
  {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={ogTitle} />
  {description && <meta name="twitter:description" content={description} />}
  
  <!-- Alternate languages (only rendered when counterpart file exists) -->
  {!is404 && <link rel="alternate" hreflang={isEnPage ? 'en' : 'ko'} href={isEnPage ? enHref : koHref} />}
  {showEnAlternate && <link rel="alternate" hreflang="en" href={enHref} />}
  {showKoAlternate && <link rel="alternate" hreflang="ko" href={koHref} />}
  {!is404 && <link rel="alternate" hreflang="x-default" href={xdefaultHref} />}
  
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <Header showAlternateLang={isEnPage ? showKoAlternate : showEnAlternate} />
  <main>
    <slot />
  </main>
  <Footer />
  <CookieBanner lang={lang} />
</body>
</html>
